{"id":-1,"name":"Onboarding diagram","userId":-1,"createdAt":"","updatedAt":"","content":{"items":[{"uid":"9aoGK73nRl","position":{"x":-850,"y":710},"sizes":{"width":400,"height":165},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authRoutes.ts - endpoint"}]},{"type":"codeBlock","attrs":{"language":null,"wrapCode":false},"content":[{"type":"text","text":"router.post(\"/register\", authController.register); "}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"LCYU2v8e-f","position":{"x":-250,"y":550},"sizes":{"width":580,"height":470},"autoheight":false,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authController.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":" Controller đẩy dữ liệu vào và nhận dữ liệu ra từ  service"}]}]}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"const register = async (req, res) => {\n  try {\n    const newUser = await authService.register(req.body);\n    console.log(newUser);\n    return res.status(201).json({\n      success: true,\n      message: \"Đăng ký thành công! Vui lòng kiểm tra email để lấy mã OTP.\",\n      data: newUser,\n    });\n  } catch (error) {\n    return res.status(500).json({\n      success: false,\n      message: \"Lỗi đăng ký: \" + error.message,\n    });\n  }\n};"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"YF8hpSTxIZ","position":{"x":560,"y":670},"sizes":{"width":830,"height":229},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authService.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Kiểm tra nhân viên đã tồn tại chưa "}]},{"type":"codeBlock","attrs":{"language":null,"wrapCode":false},"content":[{"type":"text","text":"const existing = await userRepository.getUserByEmail(userData.email); \n     if (existing.recordset.lengt h > 0) {\n  throw new Error(\"Email này đã được đăng ký trong hệ thống!\");}  "}]}]}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"Y-LlTjm6jy","position":{"x":1630,"y":660},"sizes":{"width":600,"height":246.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authService.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Service tạo dữ liệu đăng ký tạm"}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":" const manv = generateEmployeeId();\n    const otpCode = crypto.randomInt(100000, 999999).toString();\n    const expiredAt = new Date(Date.now() + 10 * 60 * 1000);\n    const encrypt edPass = encrypt(userData.password);"}]}]}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"trAYBH0JO7","position":{"x":1700,"y":1030},"sizes":{"width":460,"height":299},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authService.ts "}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Service gọi repository lưu vào DANG_KY_CHO"}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":" const stageResult = await userRepository.savePendingRegistration({\n      ...userData,\n      manv,\n      encryptedPass,\n      otpCode,\n      expiredAt,\n    });"}]}]}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"wDAjXZMYWS","position":{"x":770,"y":980},"sizes":{"width":410,"height":372.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"userRepository.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Gọi "},{"type":"text","marks":[{"type":"bold"}],"text":"getUserByEmail "},{"type":"text","text":"trong  "},{"type":"text","marks":[{"type":"bold"}],"text":"userRepository.ts "},{"type":"text","text":"sql lấy user theo email"}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"  getUserByEmail: async (email) => {\n    const result = await appPool\n      .request()\n      .input(\"Email\", sql.NVarChar, email)\n      .query(\n        \"SELECT MANV, HOTEN, EMAIL, CHUCVU  FROM NHAN_VIEN WHERE EMAIL = @Email\",\n      );\n    return result; // Trả về nguyên result để Service dùng recordset.length\n  },\n};"}]}]}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"CDvlCROEMh","position":{"x":2410,"y":770},"sizes":{"width":590,"height":824},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":" userRepository.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"SQL Lưu user vào DANG_KY_CHO"}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"savePendingRegistration: async (data) => {\n    await appPool\n      .request()\n      .input(\"MaNV\", sql.NVarChar(10), data.manv)\n      .input(\"Email\", sql.NVarChar(100), data.email)\n      .input(\"PassEnc\", sql.NVarChar(sql.MAX), data.encryptedPass)\n      .input(\"HoTen\", sql.NVarChar(200), data.hoten)\n      .input(\"MaPhg\", sql.Int, data.maphg)\n      .input(\"Luong\", sql.Decimal(18, 2), data.luong ?? 0)\n      .input(\"ChucVu\", sql.NVarChar(100), data.chucvu || \"Nhân viên\")\n      .input(\"OtpCode\", sql.NVarChar(6), data.otpCode)\n      .input(\"ExpiredAt\", sql.DateTime, data.expiredAt).query(`\n        MERGE [dbo].[DANG_KY_CHO] AS target\n        USING (SELECT @Email AS Email) AS source\n        ON (target.Email = source.Email)\n        WHEN MATCHED THEN\n            UPDATE SET\n              MaNV = @MaNV,\n              PasswordMaHoa = @PassEnc,\n              HoTen = @HoTen,\n              MaPhg = @MaPhg,\n              Luong = @Luong,\n              ChucVu = @ChucVu,\n              OtpCode = @OtpCode,\n              ExpiredAt = @ExpiredAt,\n              CreatedAt = GETDATE()\n        WHEN NOT MATCHED THEN\n            INSERT (MaNV, Email, PasswordMaHoa, HoTen, MaPhg, Luong, ChucVu, OtpCode, ExpiredAt)\n            VALUES (@MaNV, @Email, @PassEnc, @HoTen, @MaPhg, @Luong, @ChucVu, @OtpCode, @ExpiredAt);\n      `);\n\n    return {\n      Success: 1,\n      Message: \"Đã lưu thông tin tạm thời và gửi OTP\",\n    };\n  },\n"}]}]}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"UirtdUiMxA","position":{"x":1620,"y":1420},"sizes":{"width":620,"height":631.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"mailHelper.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Giửi OTP"}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"import nodemailer from \"nodemailer\";\n\nconst transporter = nodemailer.createTransport({\n  service: \"gmail\",\n  auth: {\n    user: process.env.EMAIL_USER, // Email của bạn\n    pass: process.env.EMAIL_PASS, // App Password của Gmail\n  },\n});\n\nconst sendOTPMail = async (email, otpCode) => {\n  const mailOptions = {\n    from: '\"Phòng Nhân Sự\" <no-reply@company.com>',\n    to: email,\n    subject: \"Mã xác thực đăng ký tài khoản HRM\",\n    html: `<div style=\"font-family: Arial, sans-serif; border: 1px solid #ddd; padding: 20px;\">\n            <h2>Xác thực tài khoản</h2>\n            <p>Mã OTP của bạn là: <b style=\"font-size: 24px; color: #007bff;\">${otpCode}</b></p>\n            <p>Mã này có hiệu lực trong 10 phút. Vui lòng không cung cấp mã này cho người khác.</p>\n          </div>`,\n  };\n  return transporter.sendMail(mailOptions);\n};\n\nexport { sendOTPMail };\n"}]}]}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"3po3v5Mgup","position":{"x":-1140,"y":750},"sizes":{"width":170,"height":78},"autoheight":false,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"REGISTER"}]}]},"color":{"bgColor":"hsla(140, 76%, 82%, 1)","bgName":"green-l"},"nodeType":"block"},{"uid":"kN5vVQaw3R","position":{"x":-1860,"y":2070},"sizes":{"width":190,"height":95},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"verify OTP"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"WTODVD9Eyx","position":{"x":-1460,"y":2030},"sizes":{"width":400,"height":182.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authRoutes.ts - endpoint"}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"router.post(\"/verify-otp\", authController.verifyOtp);\n"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"BqVnTohI0V","position":{"x":-920,"y":1880},"sizes":{"width":540,"height":491.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authController.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Controller đẩy dữ liệu vào và nhận dữ liệu ra từ  service"}]}]}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"const verifyOtp = async (req, res) => {\n  try {\n    const { email, otpCode } = req.body;\n    const result = await authService.verifyOTP(email, otpCode);\n\n    // Debug: Xem thực tế Service trả về cái gì\n    console.log(\"Kết quả từ Service:\", result);\n\n    // Trả về trực tiếp đối tượn g result (đã có success và message)\n    return res.status(200).json(result);\n  } catch (error) {\n    console.error(\"Lỗi tại Controller:\", error.message);\n    return res.status(400).json({\n      success: false, // Ở đây dùng viết thường cho đồng bộ với Frontend\n      message: error.message,\n    });\n  }\n};"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"Olro6qxssS","position":{"x":-150,"y":1820},"sizes":{"width":650,"height":596.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authService.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Gọi Repos viết SQL truy vấn OTP và Email"}]}]}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":" verifyOTP: async (email, otpCode) => {\n    // Bước 1: Kiểm tra OTP ở app pool\n    const pending = await userRepository.verifyPendingOtp(email, otpCode);\n    if (!pending) {\n      throw new Error(\"Mã OTP không đúng hoặc đã hết hạn\");\n    }\n\n    const originalPassword = decrypt(pending.PasswordMaHoa);\n\n    // Bước 2: OTP đúng mới tạo LOGIN ở master pool\n    await userRepository.handleServerLogin(email, originalPassword, \"CREATE\");\n\n    // Bước 3: Kích hoạt user ở app pool\n    const result = await userRepository.verifyAndActivate(email, otpCode);\n\n    if (result && result.Success === 0) {\n      throw new Error(result.Message || \"Mã OTP không đúng hoặc đã hết hạn\");\n    }\n\n    return {\n      success: true,\n      message: result?.Message || \"Xác thực và kích hoạt tài khoản thành công\",\n    };\n  },"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"WLsqAE85vJ","position":{"x":-130,"y":2570},"sizes":{"width":620,"height":456.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":" "}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph"},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"  verifyPendingOtp: async (email, otpCode) => {\n    const result = await appPool\n      .request()\n      .input(\"Email\", sql.NVarChar(100), email)\n      .input(\"OtpCode\", sql.NVarChar(6), otpCode)\n      .query(\n        `SELECT TOP 1 MaNV, Email, PasswordMaHoa, HoTen, MaPhg, Luong, ChucVu, OtpCode, ExpiredAt\n         FROM DANG_KY_CHO\n         WHERE Email = @Email\n           AND OtpCode = @OtpCode\n           AND ExpiredAt > GETDATE()`\n      );\n\n    return result.recordset[0] || null;\n  },\n"}]}]}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"vX1y0MLOvC","position":{"x":-30,"y":3210},"sizes":{"width":400,"height":105.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"User trong table DANG_KY_CHO CHUYÊN  trạng thái"},{"type":"hardBreak"},{"type":"text","text":" IsVerify: true"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"lrqJ8I_X6q","position":{"x":660,"y":2770},"sizes":{"width":140,"height":84.5},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"paragraph"}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"-_5yIDVMcK","position":{"x":-2010,"y":4140},"sizes":{"width":284.75,"height":95},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"Admin accetp user"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"z6YeVjfU5O","position":{"x":-1370,"y":4110},"sizes":{"width":600,"height":165},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authRoutes.ts - endpoint"}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"router.post(\"/onboarding/accept\", authController.acceptPendingRegistration);"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"XYVO-9Tced","position":{"x":-650,"y":4080},"sizes":{"width":400,"height":235},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authController.ts"}]},{"type":"codeBlock","attrs":{"language":null,"wrapCode":false},"content":[{"type":"text","text":"Controller đẩy dữ liệu vào và nhận dữ liệu ra từ  service\nconst acceptPendingRegistration = async (req, res) => {\n  const result = await authService.acceptPendingRegistration(req.body);\n  return res.status(200).json(result);\n};"}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"fa2E5nHd1V","position":{"x":-50,"y":3670},"sizes":{"width":720,"height":1069},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"authService.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Gọi Repos viết SQL truy vấn "}]}]}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"  acceptPendingRegistration: async (payload) => {\n    const { email, approvedBy } = payload || {};\n    if (!email) {\n      throw new Error(\"Thiếu email hồ sơ cần duyệt\");\n    }\n\n    const staged = await userRepository.getPendingApprovalByEmail(email);\n    if (!staged) {\n      throw new Error(\"Không tìm thấy hồ sơ chờ duyệt\");\n    }\n\n    if (staged.RegistrationStatus !== REGISTRATION_STATUS.OTP_VERIFIED) {\n      throw new Error(\n        `Hồ sơ không ở trạng thái OTP_VERIFIED (hiện tại: ${staged.RegistrationStatus})`,\n      );\n    }\n\n    // API duyệt chỉ cần email + thông tin nhân sự; MANV/HOTEN được tự suy ra từ hồ sơ chờ.\n    const normalizedStagedName = String(staged.HoTen || \"\").trim();\n    const fallbackName = String(email).split(\"@\")[0] || \"Nhan vien moi\";\n    const effectiveHoTen =\n      String(payload?.hoten || \"\").trim() ||\n      normalizedStagedName ||\n      fallbackName;\n    const effectiveManv =\n      String(payload?.manv || \"\").trim() ||\n      String(staged.MaNV || \"\").trim() ||\n      generateEmployeeId();\n\n    const originalPassword = decrypt(staged.PasswordMaHoa);\n    const result = await userRepository.approvePendingRegistration({\n      email,\n      password: originalPassword,\n      manv: effectiveManv,\n      hoten: effectiveHoTen,\n      maphg: payload.maphg,\n      luong: payload.luong,\n      chucvu: payload.chucvu,\n      approvedBy,\n    });\n\n    if (!result || result.Success === 0) {\n      throw new Error(result?.Message || \"Duyệt hồ sơ thất bại\");\n    }\n\n    return {\n      success: true,\n      message: result.Message,\n      data: result.Data,\n    };\n  }, "}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"},{"uid":"jXcqzagL8u","position":{"x":1190,"y":3070},"sizes":{"width":1010,"height":2259},"autoheight":true,"blockContent":{"type":"doc","content":[{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"userRepository.ts"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":" approvePendingRegistration (delete if approve success )"}]},{"type":"codeBlock","attrs":{"language":"typescript","wrapCode":false},"content":[{"type":"text","text":"  approvePendingRegistration: async (payload) => {\n    const transaction = appPool. transaction();\n    await transaction.begin();\n\n    try {\n      const safeEmailIdentifier = `[${String(payload.email).replace(/]/g, \"]]\")}]`;\n      const safeEmailLiteral = String(payload.email).replace(/'/g, \"''\");\n      const safePassword = String(payload.password).replace(/'/g, \"''\");\n\n      const stage = await new sql.Request(transaction).input(\n        \"Email\",\n        sql.NVarChar(100),\n        payload.email,\n      ).query(`\n          SELECT TOP 1 Email, MaNV, HoTen, MaPhg, Luong, ChucVu, RegistrationStatus\n          FROM DANG_KY_CHO WITH (UPDLOCK, ROWLOCK)\n          WHERE Email = @Email\n        `);\n\n      const staged = stage.recordset[0];\n      if (!staged) {\n        await transaction.rollback();\n        return { Success: 0, Message: \"Không tìm thấy hồ sơ chờ duyệt\" };\n      }\n\n      if (staged.RegistrationStatus !== REGISTRATION_STATUS.OTP_VERIFIED) {\n        await transaction.rollback();\n        return {\n          Success: 0,\n          Message: `Không thể duyệt hồ sơ ở trạng thái ${staged.RegistrationStatus}`,\n        };\n      }\n\n      const effectiveMaNV = payload.manv || staged.MaNV;\n      const effectiveHoTen = payload.hoten || staged.HoTen;\n      const effectiveMaPhg =\n        payload.maphg === undefined ? staged.MaPhg : payload.maphg;\n      const effectiveLuong =\n        payload.luong === undefined ? staged.Luong : payload.luong;\n      const effectiveChucVu = payload.chucvu || staged.ChucVu || \"Nhân viên\";\n\n      if (!effectiveMaNV || !effectiveHoTen) {\n        await transaction.rollback();\n        return {\n          Success: 0,\n          Message: \"Thiếu MANV hoặc Họ tên để duyệt nhân viên\",\n        };\n      }\n\n      await new sql.Request(transaction).query(`\n        IF NOT EXISTS (SELECT 1 FROM sys.database_principals WHERE name = N'${safeEmailLiteral}')\n        BEGIN\n          CREATE USER ${safeEmailIdentifier} WITH PASSWORD = '${safePassword}';\n        END\n      `);\n\n      await new sql.Request(transaction).query(`\n        IF NOT EXISTS (\n          SELECT 1\n          FROM sys.database_role_members drm\n          JOIN sys.database_principals rolep ON rolep.principal_id = drm.role_principal_id\n          JOIN sys.database_principals memberp ON memberp.principal_id = drm.member_principal_id\n          WHERE rolep.name = N'db_datareader' AND memberp.name = N'${safeEmailLiteral}'\n        )\n        BEGIN\n          ALTER ROLE [db_datareader] ADD MEMBER ${safeEmailIdentifier};\n        END\n\n        IF NOT EXISTS (\n          SELECT 1\n          FROM sys.database_role_members drm\n          JOIN sys.database_principals rolep ON rolep.principal_id = drm.role_principal_id\n          JOIN sys.database_principals memberp ON memberp.principal_id = drm.member_principal_id\n          WHERE rolep.name = N'db_datawriter' AND memberp.name = N'${safeEmailLiteral}'\n        )\n        BEGIN\n          ALTER ROLE [db_datawriter] ADD MEMBER ${safeEmailIdentifier};\n        END\n      `);\n\n      const existed = await new sql.Request(transaction)\n        .input(\"Email\", sql.NVarChar(100), payload.email)\n        .query(\n          `SELECT TOP 1 1 AS ExistsFlag FROM [dbo].[NHAN_VIEN] WHERE EMAIL = @Email`,\n        );\n\n      if (existed.recordset.length === 0) {\n        await new sql.Request(transaction)\n          .input(\"MaNV\", sql.NVarChar(10), effectiveMaNV)\n          .input(\"Email\", sql.NVarChar(100), payload.email)\n          .input(\"HoTen\", sql.NVarChar(200), effectiveHoTen)\n          .input(\"MaPhg\", sql.Int, effectiveMaPhg)\n          .input(\"Luong\", sql.Decimal(18, 2), effectiveLuong)\n          .input(\"ChucVu\", sql.NVarChar(100), effectiveChucVu).query(`\n            INSERT INTO [dbo].[NHAN_VIEN] (MANV, EMAIL, HOTEN, MAPHG, LUONG, CHUCVU, IsVerified)\n            VALUES (@MaNV, @Email, @HoTen, @MaPhg, @Luong, @ChucVu, 1)\n          `);\n      }\n\n      await new sql.Request(transaction).input(\n        \"Email\",\n        sql.NVarChar(100),\n        payload.email,\n      ).query(`\n          DELETE FROM DANG_KY_CHO\n          WHERE Email = @Email\n        `);\n\n      await transaction.commit();\n      return {\n        Success: 1,\n        Message: \"Duyệt nhân viên thành công\",\n        Data: { manv: effectiveMaNV, email: payload.email },\n      };\n    } catch (error) {\n      await transaction.rollback().catch(() => undefined);\n      throw error;\n    }\n  },"}]}]}]}]},"color":{"bgColor":"#ffffff","bgName":"white"},"nodeType":"block"}],"configs":{"centerX":782.2707057372857,"centerY":-2590.2516385547337,"zoomLevel":0.5444444274902344},"arrowData":{"arrowsMap":{"arrow-point-bI0wBh3Ufk-bottom-point-PSPLIYKa9J-top":{"to":"point-PSPLIYKa9J-top","from":"point-bI0wBh3Ufk-bottom","label":"Normal Box","direction":"ft","selectable":true},"arrow-point-bI0wBh3Ufk-bottom-point-ytXK_ayIc1-top":{"to":"point-ytXK_ayIc1-top","from":"point-bI0wBh3Ufk-bottom","label":"Code Box","direction":"ft","selectable":true},"arrow-point-hyyRZE3E8u-right-point-6ZopTaEaDZ-left":{"to":"point-6ZopTaEaDZ-left","from":"point-hyyRZE3E8u-right","label":"call","direction":"ft","selectable":true}},"pointsMap":{"point-PSPLIYKa9J-top":{"x":805.9999797489683,"y":60,"id":"point-PSPLIYKa9J-top","direction":"top"},"point-ytXK_ayIc1-top":{"x":205.99999493724206,"y":60,"id":"point-ytXK_ayIc1-top","direction":"top"},"point-6ZopTaEaDZ-left":{"x":220,"y":605.9999898744841,"id":"point-6ZopTaEaDZ-left","direction":"left"},"point-hyyRZE3E8u-right":{"x":100,"y":606,"id":"point-hyyRZE3E8u-right","direction":"right"},"point-bI0wBh3Ufk-bottom":{"x":515.9999797489683,"y":-40,"id":"point-bI0wBh3Ufk-bottom","direction":"bottom"}},"edgesMap":{"edge-9aoGK73nRl-9aoGK73nRl-right-LCYU2v8e-f-LCYU2v8e-f-left":{"uid":"edge-9aoGK73nRl-9aoGK73nRl-right-LCYU2v8e-f-LCYU2v8e-f-left","fromNodeId":"9aoGK73nRl","fromHandleId":"9aoGK73nRl-right","toN